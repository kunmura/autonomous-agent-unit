# =============================================================================
# Autonomous Agent Unit (AAU) — Configuration
# =============================================================================
# このファイルをプロジェクトルートに aau.yaml としてコピーして編集してください。
# Copy this file to your project root as aau.yaml and customize.
# =============================================================================

project:
  name: "my-project"
  # repo_path is auto-detected from aau.yaml location; override if needed
  # repo_path: "/path/to/project"

runtime:
  claude_cli: "/opt/homebrew/bin/claude"
  claude_model: "claude-sonnet-4-6"
  permission_mode: "bypassPermissions"
  tmp_dir: "/tmp"
  # prefix for all temp files: /tmp/{prefix}_*
  prefix: "myproj"

team:
  members:
    - name: coder
      role: "Implementation and testing"
      timeout: 600
      max_turns: 30
      interval: 300
      tools: "Read,Write,Edit,Bash,Grep,Glob"
    - name: qa
      role: "Quality assurance and test execution"
      timeout: 600
      max_turns: 30
      interval: 300
      tools: "Read,Write,Edit,Bash,Grep,Glob"
  # ── Tool permissions per role (examples) ──
  # researcher: "Read,Write,Edit,Bash,WebSearch,WebFetch"  ← Web search required
  # analyst:    "Read,Write,Edit,Bash"
  # writer:     "Read,Write,Edit"
  # critic:     "Read,Write,Edit,WebSearch,WebFetch"        ← Fact-checking requires web
  # director:   "Read,Write,Edit,Bash"                      ← curl for Slack

director:
  autonomous_interval: 1800
  responder_interval: 120
  timeout: 600
  max_turns:
    milestone: 10
    report: 15
    followup: 20
    stale: 10
    idle: 25
    respond: 40
  report_interval: 7200
  stale_threshold: 1800
  approval_reminder_interval: 21600  # 6h — notify producer when approval pending
  daily_max_invocations: 20
  # Legacy quiet hours (deprecated — use schedule: block instead)
  # quiet_hours_start: 0
  # quiet_hours_end: 8

# ── Schedule (replaces quiet_hours) ──────────────────────────────────────
schedule:
  timezone: "Asia/Tokyo"          # Explicit timezone (IANA format)
  active_hours: "08:00-23:00"     # 24h format — system runs only within this window
  breaks:                         # Pause periods within active_hours
    - "12:00-13:00"               # Lunch break
    # - "18:00-19:00"             # Dinner break (optional)
  weekend:
    mode: "reduced"               # off = full stop / reduced = limited hours / normal = same as weekday
    active_hours: "10:00-18:00"   # Used when mode is "reduced"
  overrides:                      # Per-component overrides (optional)
    director:
      active_hours: "08:00-22:00" # Director stops earlier (no late-night Slack posts)
    agents:
      active_hours: "08:00-23:00" # Agents can work a bit later
  # Emergency override: send "緊急稼働" or "緊急稼働 30分" in Slack to temporarily
  # disable schedule restrictions. Default duration: 60 minutes.

scheduling:
  task_monitor_interval: 300
  health_monitor_interval: 600

locks:
  max_age: 1800

retry:
  max_retries: 3
  backoff_base: 300

notification:
  # slack | discord | webhook | none
  plugin: "none"
  report_style: "short"
  report_max_chars: 50
  # Alert when project cost exceeds this amount (USD)
  cost_alert_threshold: 10

slack:
  # Required for Slack two-way communication (producer <-> director)
  producer_id: ""    # Slack user ID of the producer (e.g. UK25H386P)
  bot_id: ""         # Slack bot user ID (e.g. U0AK6BHNV6H)
  # Keyword to trigger recording (e.g. "録画", "record"). Set to "" to disable.
  record_keyword: ""

local_llm:
  enabled: false
  url: "http://localhost:11434/api/generate"
  classifier_model: "gemma2:9b"
  drafter_model: "qwen2.5-coder:32b"
  classifier_timeout: 30
  drafter_timeout: 300

prompts:
  language: "ja"
  # custom_dir: "prompts/"  # override template prompts

agents:
  # Max launches per agent per day (prevents runaway cost)
  daily_max: 50
  # Max rapid launches in 30min before cooldown activates
  max_rapid_launches: 4

health:
  critical_patterns:
    - "Reached max turns"
    - "max turns exceeded"
    - "agent timed out after"
    - "permission denied"
    - "Edit not allowed"
    - "Write not allowed"
    - "Tool not allowed"
    - "allowedTools does not include"
    - "requires permission"
  warning_patterns:
    - "TESTS FAILED"
    - "assert failed"
    - "Error: "
    - "BLOCKED"
    - "Traceback (most recent"
  stale_threshold: 1500
  # Relaunch loop detection: alert when agent launches N+ times with 0 completions
  relaunch_window_min: 60
  relaunch_critical_count: 5
